<Window x:Class="Excel.ColumnSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Oszlop beállítások"
        Height="500"
        Width="600"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Név oszlop -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Név oszlop:" FontWeight="Bold"/>
            <ComboBox x:Name="NameColumnComboBox"
                      Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Lakásszám oszlop -->
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="Lakásszám oszlop:" FontWeight="Bold"/>
            <ComboBox x:Name="ApartmentColumnComboBox"
                      Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Opció oszlopok -->
        <StackPanel Grid.Row="2">
            <TextBlock Text="Opció oszlopok (több is lehet):"
                       FontWeight="Bold"/>

            <ScrollViewer Grid.Row="2"
              VerticalScrollBarVisibility="Auto"
              HorizontalScrollBarVisibility="Disabled"
              Height="200">

                <ListBox x:Name="OptionColumnsListBox"
             SelectionMode="Multiple"/>
            </ScrollViewer>
        </StackPanel>

        <!-- Mentés gomb -->
        <Button Grid.Row="3"
                Content="Mentés"
                Width="120"
                Height="35"
                HorizontalAlignment="Right"
                Margin="0,20,0,0"
                Click="Save_Click"/>
    </Grid>
</Window>