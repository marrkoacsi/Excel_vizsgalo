<Window x:Class="Excel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Excel Merge Tool"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>


        <!-- HEADER -->
        <Border Background="#1E293B"
                CornerRadius="8"
                Padding="15"
                Margin="0,0,0,20">

            <TextBlock Text="Excel Merge Tool"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"/>
        </Border>


        <!-- FILE SECTION -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="8"
                Padding="15"
                Margin="0,0,0,15">

            <StackPanel>

                <TextBlock Text="Fájlok"
                           FontWeight="Bold"
                           FontSize="16"
                           Margin="0,0,0,10"/>

                <!-- Összesítő -->
                <StackPanel Orientation="Horizontal" Margin="0,5">

                    <TextBlock Text="Összesítő:"
                               Width="150"
                               VerticalAlignment="Center"/>

                    <Button Content="Tallózás"
                            Width="120"
                            Click="BrowseOsszesito_Click"/>

                    <Button Content="Oszlop beállítás"
                            Width="150"
                            Margin="10,0"
                            Click="OpenColumnSettings_Click"/>

                </StackPanel>

                <!-- Apollo -->
                <StackPanel Orientation="Horizontal" Margin="0,5">

                    <TextBlock Text="Apollo lekérdezés:"
                               Width="150"
                               VerticalAlignment="Center"/>

                    <Button Content="Tallózás"
                            Width="120"
                            Click="BrowseApollo_Click"/>

                    <Button Content="Apollo oszlopok"
                            Width="150"
                            Margin="10,0"
                            Click="OpenApolloColumnSettings_Click"/>

                </StackPanel>

                <!-- Módosítandó -->
                <StackPanel Orientation="Horizontal" Margin="0,5">

                    <TextBlock Text="Módosítandó fájl:"
                               Width="150"
                               VerticalAlignment="Center"/>

                    <Button Content="Tallózás"
                            Width="120"
                            Click="BrowseModositando_Click"/>

                </StackPanel>

            </StackPanel>

        </Border>


        <!-- ACTION SECTION -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="8"
                Padding="15"
                Margin="0,0,0,15">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Content="Elemzés"
                        Height="45"
                        FontWeight="Bold"
                        Background="#22C55E"
                        Foreground="White"
                        Click="Analyze_Click"/>

                <Button Grid.Column="1"
                        Content="Módosítás mentése"
                        Height="45"
                        Margin="15,0"
                        FontWeight="Bold"
                        Background="#3B82F6"
                        Foreground="White"
                        Click="SaveChanges_Click"/>

                <Button Grid.Column="2"
                        Content="Részletfizetés (debug)"
                        Height="45"
                        Margin="15,0"
                        FontWeight="Bold"
                        Background="#6366F1"
                        Foreground="White"
                        Click="RunApolloAI_Click"/>

                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Kimeneti fájl neve"/>
                        <TextBox x:Name="OutputFileNameBox"
                                 Width="180"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Kimeneti oszlop"/>
                        <TextBox x:Name="OutputStartColumnBox"
                                 Width="60"/>
                    </StackPanel>

                </StackPanel>

            </Grid>

        </Border>


        <!-- RESULT GRID -->
        <Border Grid.Row="4"
                Background="White"
                CornerRadius="8"
                Padding="10">

            <DataGrid x:Name="PreviewGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      AlternatingRowBackground="#F1F5F9"
                      GridLinesVisibility="None">

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>

                            <DataTrigger Binding="{Binding MatchType}" Value="CE_single">
                                <Setter Property="Background" Value="#DCFCE7"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding MatchType}" Value="Apollo_match">
                                <Setter Property="Background" Value="#DBEAFE"/>
                            </DataTrigger>

                            <DataTrigger Binding="{Binding MatchType}" Value="Manual_review">
                                <Setter Property="Background" Value="#FEE2E2"/>
                            </DataTrigger>

                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Lakásszám" Binding="{Binding Apartment}" Width="120"/>
                    <DataGridTextColumn Header="Név" Binding="{Binding Name}" Width="200"/>
                    <DataGridTextColumn Header="Módosítás" Binding="{Binding ModositasNev}" Width="200"/>
                    <DataGridTextColumn Header="Blokk" Binding="{Binding BlockName}" Width="120"/>
                    <DataGridTextColumn Header="Bruttó" Binding="{Binding Brutto}" Width="120"/>
                    <DataGridTextColumn Header="Nettó" Binding="{Binding Netto}" Width="120"/>
                    <DataGridTextColumn Header="ÁFA" Binding="{Binding Afa}" Width="80"/>
                    <DataGridTextColumn Header="Match típus" Binding="{Binding MatchType}" Width="140"/>

                </DataGrid.Columns>

            </DataGrid>

        </Border>


        <!-- STATUS -->
        <StackPanel Grid.Row="5">

            <ProgressBar x:Name="MainProgressBar"
                         Height="20"
                         Minimum="0"
                         Maximum="100"
                         Visibility="Collapsed"
                         Margin="0,10,0,5"/>

            <TextBlock x:Name="StatsText"
                       FontWeight="Bold"/>

        </StackPanel>

    </Grid>
</Window>