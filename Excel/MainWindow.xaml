<Window x:Class="Excel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Excel Tool Suite"
        Height="800"
        Width="1260"
        WindowStartupLocation="CenterScreen"
        Background="#080B12"
        FontFamily="Segoe UI">

    <Window.Resources>

        <DropShadowEffect x:Key="CardShadow" BlurRadius="24" ShadowDepth="2" Opacity="0.25" Color="#000000"/>

        <!-- ACTION BUTTON -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Height"                Value="44"/>
            <Setter Property="FontWeight"            Value="SemiBold"/>
            <Setter Property="FontSize"              Value="13"/>
            <Setter Property="Foreground"            Value="White"/>
            <Setter Property="BorderThickness"       Value="0"/>
            <Setter Property="Cursor"                Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10" Padding="20,0">
                            <Border.Effect>
                                <DropShadowEffect x:Name="Glow" BlurRadius="0" ShadowDepth="0" Opacity="0" Color="#000"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.04" Duration="0:0:0.14"/>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.04" Duration="0:0:0.14"/>
                                        <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="BlurRadius" To="22" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity"    To="0.65" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1"   Duration="0:0:0.14"/>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1"   Duration="0:0:0.14"/>
                                        <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="BlurRadius" To="0" Duration="0:0:0.14"/>
                                        <DoubleAnimation Storyboard.TargetName="Glow" Storyboard.TargetProperty="Opacity"    To="0" Duration="0:0:0.14"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="0.97" Duration="0:0:0.07"/>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="0.97" Duration="0:0:0.07"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1.04" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1.04" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- GHOST BUTTON -->
        <Style x:Key="GhostBtn" TargetType="Button">
            <Setter Property="Height"          Value="34"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Foreground"      Value="#94A3B8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="#252D3E"/>
            <Setter Property="Background"      Value="#131928"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#1C2438" Duration="0:0:0.13"/>
                                        <ColorAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#3D4F6E" Duration="0:0:0.13"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#131928" Duration="0:0:0.13"/>
                                        <ColorAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#252D3E" Duration="0:0:0.13"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="0.97" Duration="0:0:0.07"/>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="0.97" Duration="0:0:0.07"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX" To="1" Duration="0:0:0.1"/>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY" To="1" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- MODERN TEXTBOX -->
        <Style x:Key="ModernTB" TargetType="TextBox">
            <Setter Property="Background"      Value="#0E1420"/>
            <Setter Property="Foreground"      Value="#E2E8F0"/>
            <Setter Property="BorderBrush"     Value="#252D3E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,7"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="CaretBrush"      Value="#3B82F6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Opacity="0.45" Color="#3B82F6"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- PROGRESS BAR -->
        <Style x:Key="ModernPB" TargetType="ProgressBar">
            <Setter Property="Height"          Value="5"/>
            <Setter Property="Background"      Value="#131928"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="3">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#3B82F6" Offset="0"/>
                                            <GradientStop Color="#8B5CF6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.7" Color="#3B82F6"/>
                                    </Border.Effect>
                                </Border>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TAB CONTROL -->
        <Style x:Key="AppTabControl" TargetType="TabControl">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TabPanel Grid.Row="0" IsItemsHost="True" Background="Transparent"/>
                            <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppTabItem" TargetType="TabItem">
            <Setter Property="Foreground"      Value="#4A5568"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Background="Transparent" Padding="0,0,36,0">
                            <StackPanel>
                                <TextBlock x:Name="TabLabel"
                                           Text="{TemplateBinding Header}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Foreground="#4A5568"
                                           Margin="0,0,0,10"/>
                                <Border x:Name="Underline" Height="2" CornerRadius="1" Background="Transparent"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabLabel"  Property="Foreground" Value="White"/>
                                <Setter TargetName="Underline" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#3B82F6" Offset="0"/>
                                            <GradientStop Color="#8B5CF6" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DATAGRID STYLES -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#0B0F1A"/>
            <Setter Property="Foreground"      Value="#4A5568"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Padding"         Value="14,10"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,0"/>
            <Setter Property="Foreground"      Value="#94A3B8"/>
            <Setter Property="FontSize"        Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#1A2540"/>
                    <Setter Property="Foreground"  Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- SEPARATOR LINE -->
        <Style x:Key="HSep" TargetType="Separator">
            <Setter Property="Background"  Value="#1A2438"/>
            <Setter Property="Height"      Value="1"/>
            <Setter Property="Margin"      Value="0,14,0,14"/>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════
             HEADER
        ══════════════════════════════ -->
        <Border Background="#0A0D16"
                BorderBrush="#151E2E"
                BorderThickness="0,0,0,1"
                Padding="28,16,28,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,14">
                    <Border Width="4" Height="26" CornerRadius="2" Margin="0,0,14,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#3B82F6" Offset="0"/>
                                <GradientStop Color="#8B5CF6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <TextBlock Text="Excel Tool Suite"
                               Foreground="White"
                               FontSize="17"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#0C1F37"
                        CornerRadius="20"
                        Padding="12,6"
                        VerticalAlignment="Center"
                        Margin="0,0,0,14">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,7,0">
                            <Ellipse.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#3B82F6" Offset="0"/>
                                    <GradientStop Color="#22C55E" Offset="1"/>
                                </LinearGradientBrush>
                            </Ellipse.Fill>
                        </Ellipse>
                        <TextBlock Text="Készen áll" Foreground="#3B82F6" FontSize="12"/>
                    </StackPanel>
                </Border>

                <TabControl x:Name="MainTabControl"
                            Grid.Row="1"
                            Grid.ColumnSpan="2"
                            Style="{StaticResource AppTabControl}">

                    <!-- ══════════════════════════════
                         TAB 1 — EXCEL MERGE TOOL
                    ══════════════════════════════ -->
                    <TabItem Header="Excel Merge Tool" Style="{StaticResource AppTabItem}">
                        <Grid Margin="0,20,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- FÁJLOK KÁRTYA -->
                            <Border Background="#0F1520"
                                    CornerRadius="14"
                                    Padding="24,20"
                                    Margin="0,0,0,14"
                                    BorderBrush="#1A2438"
                                    BorderThickness="1"
                                    Effect="{StaticResource CardShadow}">
                                <StackPanel>
                                    <TextBlock Text="B E M E N E T I   F A J L O K"
                                               Foreground="#2D3A52"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,18"/>

                                    <!-- Összesítő -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Összesítő" Foreground="#64748B" FontSize="13" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="Tallózás" Style="{StaticResource GhostBtn}" Width="110" Click="BrowseOsszesito_Click"/>
                                        <Button Grid.Column="2" Content="Oszlop beállítás" Style="{StaticResource GhostBtn}" Width="145" Margin="8,0,0,0" Click="OpenColumnSettings_Click"/>
                                        <Border Grid.Column="3" Background="#080C15" CornerRadius="7" Padding="12,7" Margin="10,0,0,0">
                                            <TextBlock x:Name="OsszesitoPathText" Text="Nincs fájl kiválasztva" Foreground="#2D3A52" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </Grid>

                                    <Separator Style="{StaticResource HSep}"/>

                                    <!-- Apollo -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Apollo lekérdezés" Foreground="#64748B" FontSize="13" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="Tallózás" Style="{StaticResource GhostBtn}" Width="110" Click="BrowseApollo_Click"/>
                                        <Button Grid.Column="2" Content="Apollo oszlopok" Style="{StaticResource GhostBtn}" Width="145" Margin="8,0,0,0" Click="OpenApolloColumnSettings_Click"/>
                                        <Border Grid.Column="3" Background="#080C15" CornerRadius="7" Padding="12,7" Margin="10,0,0,0">
                                            <TextBlock x:Name="ApolloPathText" Text="Nincs fájl kiválasztva" Foreground="#2D3A52" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </Grid>

                                    <Separator Style="{StaticResource HSep}"/>

                                    <!-- Módosítandó -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Módosítandó fájl" Foreground="#64748B" FontSize="13" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="Tallózás" Style="{StaticResource GhostBtn}" Width="110" Click="BrowseModositando_Click"/>
                                        <Border Grid.Column="2" Background="#080C15" CornerRadius="7" Padding="12,7" Margin="10,0,0,0">
                                            <TextBlock x:Name="ModositandoPathText" Text="Nincs fájl kiválasztva" Foreground="#2D3A52" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- AKCIÓK KÁRTYA -->
                            <Border Grid.Row="1"
                                    Background="#0F1520"
                                    CornerRadius="14"
                                    Padding="24,18"
                                    Margin="0,0,0,14"
                                    BorderBrush="#1A2438"
                                    BorderThickness="1"
                                    Effect="{StaticResource CardShadow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Elemzés / Előnézet -->
                                    <Button Grid.Column="0"
                                            Style="{StaticResource ActionBtn}"
                                            Width="168"
                                            Click="Analyze_Click">
                                        <Button.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#15803D" Offset="0"/>
                                                <GradientStop Color="#22C55E" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Button.Background>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#x25B6;" FontSize="10" VerticalAlignment="Center" Margin="0,1,9,0"/>
                                            <TextBlock Text="Előnézet" FontSize="13"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Divider -->
                                    <Border Grid.Column="1" Width="1" Background="#1A2438" VerticalAlignment="Stretch" Margin="0,6"/>

                                    <!-- Mentés -->
                                    <Button Grid.Column="2"
                                            Style="{StaticResource ActionBtn}"
                                            Width="210"
                                            Click="SaveChanges_Click">
                                        <Button.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#1D4ED8" Offset="0"/>
                                                <GradientStop Color="#3B82F6" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Button.Background>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#x1F4BE;" FontSize="13" VerticalAlignment="Center" Margin="0,0,9,0"/>
                                            <TextBlock Text="Mentés másként..." FontSize="13"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Divider -->
                                    <Border Grid.Column="3" Width="1" Background="#1A2438" VerticalAlignment="Stretch" Margin="0,6"/>

                                    <!-- Kimeneti oszlop -->
                                    <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                        <TextBlock Text="Kimeneti oszlop" Foreground="#2D3A52" FontSize="11" Margin="0,0,0,5"/>
                                        <TextBox x:Name="OutputStartColumnBox"
                                                 Style="{StaticResource ModernTB}"
                                                 Width="72"/>
                                    </StackPanel>

                                    <!-- Kimeneti fájl útvonal kijelzés -->
                                    <Border Grid.Column="6"
                                            Background="#080C15"
                                            CornerRadius="7"
                                            Padding="12,7"
                                            VerticalAlignment="Center"
                                            MinWidth="200"
                                            MaxWidth="380">
                                        <TextBlock x:Name="OutputFilePathText"
                                                   Text="Mentési útvonal nincs megadva"
                                                   Foreground="#2D3A52"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- PREVIEW DATAGRID -->
                            <Border Grid.Row="2"
                                    Background="#0F1520"
                                    CornerRadius="14"
                                    BorderBrush="#1A2438"
                                    BorderThickness="1"
                                    Effect="{StaticResource CardShadow}"
                                    ClipToBounds="True">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Background="#080C15" Padding="18,12" BorderBrush="#151E2E" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <TextBlock Text="E L O N E Z E T" Foreground="#2D3A52" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                                                    <Border Width="9" Height="9" CornerRadius="2" Background="#14532D" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="CE single" Foreground="#2D3A52" FontSize="11"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,14,0">
                                                    <Border Width="9" Height="9" CornerRadius="2" Background="#1E3A5F" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Apollo match" Foreground="#2D3A52" FontSize="11"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Border Width="9" Height="9" CornerRadius="2" Background="#4A1010" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Manual review" Foreground="#2D3A52" FontSize="11"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <DataGrid x:Name="PreviewGrid"
                                              Grid.Row="1"
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              Background="Transparent"
                                              RowBackground="#0F1520"
                                              AlternatingRowBackground="#0C1018"
                                              GridLinesVisibility="Horizontal"
                                              HorizontalGridLinesBrush="#131928"
                                              BorderThickness="0"
                                              ColumnHeaderHeight="40"
                                              RowHeight="40"
                                              SelectionMode="Single"
                                              SelectionUnit="FullRow">
                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Setter Property="Foreground" Value="#94A3B8"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MatchType}" Value="CE_single">
                                                        <Setter Property="Background" Value="#081A0F"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding MatchType}" Value="Apollo_match">
                                                        <Setter Property="Background" Value="#081525"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding MatchType}" Value="Manual_review">
                                                        <Setter Property="Background" Value="#1A0808"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1A2540"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.RowStyle>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="LAKASSZAM" Binding="{Binding Apartment}"    Width="130"/>
                                            <DataGridTextColumn Header="NEV"        Binding="{Binding Name}"         Width="200"/>
                                            <DataGridTextColumn Header="MODOSITAS"  Binding="{Binding ModositasNev}" Width="180"/>
                                            <DataGridTextColumn Header="BLOKK"      Binding="{Binding BlockName}"    Width="130"/>
                                            <DataGridTextColumn Header="BRUTTO"     Binding="{Binding BruttoFormatted}" Width="130"/>
                                            <DataGridTextColumn Header="NETTO"      Binding="{Binding NettoFormatted}"  Width="130"/>
                                            <DataGridTextColumn Header="AFA %"      Binding="{Binding Afa}"          Width="80"/>
                                            <DataGridTextColumn Header="MATCH"      Binding="{Binding MatchType}"    Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Grid>
                            </Border>

                        </Grid>
                    </TabItem>


                    <!-- ══════════════════════════════
                         TAB 2 — RÉSZLETFIZETÉS
                    ══════════════════════════════ -->
                    <TabItem Header="Részletfizetés" Style="{StaticResource AppTabItem}">
                        <Grid Margin="0,20,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Info banner -->
                            <Border Background="#0C1525"
                                    CornerRadius="12"
                                    Padding="20,16"
                                    Margin="0,0,0,14"
                                    BorderBrush="#1A2E4A"
                                    BorderThickness="1">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="36" Height="36" CornerRadius="18" Margin="0,0,14,0" VerticalAlignment="Center">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#1D4ED8" Offset="0"/>
                                                <GradientStop Color="#7C3AED" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <TextBlock Text="&#x26A1;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Apollo Részletfizetés feldolgozó" Foreground="#93C5FD" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="Automatikus számlafeldolgozás Apollo Excel exportból és devizás számlákból" Foreground="#3B5278" FontSize="12" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- FÁJLOK KÁRTYA -->
                            <Border Grid.Row="1"
                                    Background="#0F1520"
                                    CornerRadius="14"
                                    Padding="24,20"
                                    Margin="0,0,0,14"
                                    BorderBrush="#1A2438"
                                    BorderThickness="1"
                                    Effect="{StaticResource CardShadow}">
                                <StackPanel>
                                    <TextBlock Text="B E M E N E T I   F A J L O K"
                                               Foreground="#2D3A52"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,18"/>

                                    <!-- Részletfizetés fájlok (TÖBB fájl) -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Részletfizetés fájlok" Foreground="#64748B" FontSize="13"/>
                                            <TextBlock Text="(több fájl)" Foreground="#2D3A52" FontSize="10" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Tallózás" Style="{StaticResource GhostBtn}" Width="110" Click="BrowseInstallment_Click"/>
                                        <Border Grid.Column="2" Background="#080C15" CornerRadius="7" Padding="12,7" Margin="10,0,0,0">
                                            <TextBlock x:Name="InstallmentFilesText" Text="Nincs fájl kiválasztva" Foreground="#2D3A52" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </Grid>

                                    <Separator Style="{StaticResource HSep}"/>

                                    <!-- Deviza fájl (EGY fájl) -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Deviza fájl" Foreground="#64748B" FontSize="13"/>
                                            <TextBlock Text="(egy fájl)" Foreground="#2D3A52" FontSize="10" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Tallózás" Style="{StaticResource GhostBtn}" Width="110" Click="BrowseDeviza_Click"/>
                                        <Border Grid.Column="2" Background="#080C15" CornerRadius="7" Padding="12,7" Margin="10,0,0,0">
                                            <TextBlock x:Name="DevizaFileText" Text="Nincs fájl kiválasztva" Foreground="#2D3A52" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- EREDMÉNY KÁRTYA -->
                            <Border Grid.Row="2"
                                    Background="#0F1520"
                                    CornerRadius="14"
                                    BorderBrush="#1A2438"
                                    BorderThickness="1"
                                    Effect="{StaticResource CardShadow}"
                                    ClipToBounds="True">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Background="#0A0E1A" Padding="18,14" BorderBrush="#151E2E" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">

                                                <!-- ELŐNÉZET gomb -->
                                                <Button Style="{StaticResource ActionBtn}"
                                                        Width="200"
                                                        Margin="0,0,10,0"
                                                        Click="PreviewInstallment_Click">
                                                    <Button.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#15803D" Offset="0"/>
                                                            <GradientStop Color="#22C55E" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Button.Background>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#x25B6;" FontSize="10" VerticalAlignment="Center" Margin="0,1,9,0"/>
                                                        <TextBlock Text="Előnézet" FontSize="13"/>
                                                    </StackPanel>
                                                </Button>

                                                <!-- MENTÉS gomb -->
                                                <Button Style="{StaticResource ActionBtn}"
                                                        Width="220"
                                                        Click="SaveInstallment_Click">
                                                    <Button.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#1D4ED8" Offset="0"/>
                                                            <GradientStop Color="#3B82F6" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Button.Background>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#x1F4BE;" FontSize="13" VerticalAlignment="Center" Margin="0,0,9,0"/>
                                                        <TextBlock Text="Mentés másként..." FontSize="13"/>
                                                    </StackPanel>
                                                </Button>

                                            </StackPanel>

                                            <TextBlock x:Name="ApolloStatsText"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       Foreground="#2D3A52"
                                                       FontSize="13"/>
                                        </Grid>
                                    </Border>

                                    <ProgressBar x:Name="ApolloProgressBar"
                                                 Grid.Row="1"
                                                 Style="{StaticResource ModernPB}"
                                                 Minimum="0" Maximum="100"
                                                 Visibility="Collapsed"/>

                                    <DataGrid x:Name="InstallmentPreviewGrid"
                                              Grid.Row="2"
                                              AutoGenerateColumns="True"
                                              IsReadOnly="True"
                                              Background="Transparent"
                                              RowBackground="#0F1520"
                                              AlternatingRowBackground="#0C1018"
                                              GridLinesVisibility="Horizontal"
                                              HorizontalGridLinesBrush="#131928"
                                              BorderThickness="0"
                                              ColumnHeaderHeight="40"
                                              RowHeight="40"
                                              SelectionMode="Single"
                                              SelectionUnit="FullRow">
                                        <DataGrid.RowStyle>
                                            <Style TargetType="DataGridRow">
                                                <Setter Property="Foreground" Value="#94A3B8"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#1A2540"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGrid.RowStyle>
                                    </DataGrid>
                                </Grid>
                            </Border>

                        </Grid>
                    </TabItem>

                </TabControl>
            </Grid>
        </Border>


        <!-- ══════════════════════════════
             STATUS BAR
        ══════════════════════════════ -->
        <Border Grid.Row="2"
                Background="#0A0D16"
                BorderBrush="#151E2E"
                BorderThickness="0,1,0,0"
                Padding="28,11">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatsText"
                           Foreground="#2D3A52"
                           FontSize="13"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <ProgressBar x:Name="MainProgressBar"
                                 Style="{StaticResource ModernPB}"
                                 Minimum="0" Maximum="100"
                                 Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
