<Window x:Class="Excel.ApolloColumnSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Apollo oszlop beállítások"
        Height="350"
        Width="400"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="20">

        <TextBlock Text="Név oszlop:"/>
        <ComboBox x:Name="NameCombo" Margin="0,5,0,15"/>

        <TextBlock Text="Bruttó oszlop:"/>
        <ComboBox x:Name="BruttoCombo" Margin="0,5,0,15"/>

        <TextBlock Text="Nettó oszlop:"/>
        <ComboBox x:Name="NettoCombo" Margin="0,5,0,15"/>

        <TextBlock Text="ÁFA oszlop:"/>
        <ComboBox x:Name="AfaCombo" Margin="0,5,0,20"/>

        <Button Content="Mentés"
                Width="100"
                HorizontalAlignment="Right"
                Click="Save_Click"/>

    </StackPanel>
</Window>